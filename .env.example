# Supabase Configuration
# Required only if you are re-running the data extraction pipeline
# (scripts/data_pipeline). Not needed to train or evaluate the model from
# a Parquet/CSV snapshot.
#
# Find these in your Supabase project dashboard: Settings > API.
# DATABASE_URL is the project URL; SUPABASE_SERVICE_ROLE_KEY is the
# service_role secret (never commit it).
DATABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
